{
  "name": "@psico/api",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "prisma generate && nest build",
    "dev": "nest start --watch",
    "dev:worker": "nest start --watch --entryFile worker",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "start:worker": "node dist/worker",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:cov": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "migrate:deploy": "prisma migrate deploy",
    "gen:vapid": "node scripts/gen-vapid.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@nestjs-modules/ioredis": "^2.2.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.3.9",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.3.9",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.3.9",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@psico/types": "workspace:*",
    "@sentry/node": "^8.55.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.77.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "google-auth-library": "^9.15.1",
    "ioredis": "^5.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.8.0",
    "rxjs": "^7.8.1",
    "stripe": "^22.1.0",
    "voyageai": "^0.2.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.9",
    "@psico/eslint-config": "workspace:*",
    "@psico/typescript-config": "workspace:*",
    "@swc/core": "^1.15.40",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.2",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@types/web-push": "^3.6.4",
    "ioredis-mock": "^8.13.1",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "unplugin-swc": "^1.5.9",
    "vitest": "^1.6.0"
