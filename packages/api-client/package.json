{
  "name": "@psico/api-client",
  "version": "0.0.4",
  "private": true,
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@psico/types": "workspace:*"
  },
  "devDependencies": {
    "@psico/eslint-config": "workspace:*",
    "@psico/typescript-config": "workspace:*",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  }
}
