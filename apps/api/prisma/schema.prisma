generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  PSYCHOLOGIST
  ADMIN
}

enum Plan {
  FREE
  PRO
  ANNUAL
  B2B
}

enum ExerciseType {
  REFLECTION
  QUIZ
  BREATHING
  JOURNALING
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  avatarUrl     String?
  role          Role     @default(USER)
  plan          Plan     @default(FREE)
  isActive      Boolean  @default(true)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stripeCustomerId String? @unique

  profile       Profile?
  refreshTokens RefreshToken[]
  progress      UserProgress[]
  subscription  Subscription?
  conversations Conversation[]

  @@index([email])
}

model Profile {
  id                String  @id @default(cuid())
  userId            String  @unique
  bio               String?
  country           String? // ISO 3166-1 alpha-2 (e.g. "EC", "MX")
  timezone          String? // IANA tz name (e.g. "America/Guayaquil")
  preferredLanguage String? // BCP 47 tag (e.g. "es", "en")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String    @id @default(cuid())
  // TODO senior: token stores SHA-256 hash — never the raw token
  token     String    @unique
  userId    String
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Book {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  description   String?
  coverUrl      String?
  // TODO senior: totalChapters is a denormalized count — keep in sync on every Chapter create/delete
  totalChapters Int      @default(0)
  isPublished   Boolean  @default(false)
  plan          Plan     @default(FREE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chapters Chapter[]
}

model Chapter {
  id              String   @id @default(cuid())
  bookId          String
  order           Int
  title           String
  description     String?
  durationMinutes Int?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  book      Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  audios    Audio[]
  exercises Exercise[]
  progress  UserProgress[]

  @@unique([bookId, order])
  @@index([bookId])
}

model Audio {
  id              String   @id @default(cuid())
  chapterId       String
  title           String
  fileUrl         String
  durationSeconds Int
  transcription   String?
  createdAt       DateTime @default(now())

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
}

model Exercise {
  id        String       @id @default(cuid())
  chapterId String
  order     Int
  title     String
  type      ExerciseType
  content   Json
  createdAt DateTime     @default(now())

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  chapterId   String
  completedAt DateTime @default(now())
  score       Float?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String             @unique
  stripePriceId        String
  stripeCustomerId     String
  status               SubscriptionStatus
  plan                 Plan
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
}

model StripeEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime
  createdAt     DateTime @default(now())

  @@index([stripeEventId])
}

// ─── AI / RAG models ──────────────────────────────────────────────────────────

model ContentChunk {
  id        String                      @id @default(cuid())
  bookId    String
  chapterId String?
  content   String
  // SHA-256 of content — used for idempotent upsert during ingest
  chunkHash String                      @unique
  metadata  Json
  // voyage-3 produces 1024-dimensional embeddings
  embedding Unsupported("vector(1024)")?
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt

  @@index([bookId])
  @@index([chapterId])
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([userId])
}

enum MessageRole {
  USER
  ASSISTANT
}

model ConversationMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  inputTokens    Int         @default(0)
  outputTokens   Int         @default(0)
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}
