generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  AUTHOR
  PSYCHOLOGIST
  ADMIN
}

enum Plan {
  FREE
  PRO
  ANNUAL
  B2B
}

enum ExerciseType {
  REFLECTION
  QUIZ
  BREATHING
  JOURNALING
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

// LOCAL: classic email + password (passwordHash required)
// GOOGLE: signed in with Google ID token (passwordHash null; providerId = Google `sub` claim)
// Future: APPLE (deferred, design says wait until we have an Apple Developer account)
enum AuthProvider {
  LOCAL
  GOOGLE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  // passwordHash is optional because OAuth users (authProvider != LOCAL) have
  // no password — they authenticate through their identity provider. The
  // service layer enforces "LOCAL → must have hash, GOOGLE → must NOT".
  passwordHash  String?
  name          String
  // firstName is nullable initially; backfilled from `name` by data migration before the field is made required
  firstName     String?
  city          String?
  avatarUrl     String?
  role          Role         @default(USER)
  plan          Plan         @default(FREE)
  isActive      Boolean      @default(true)
  emailVerified Boolean      @default(false)
  // How this account authenticates. LOCAL is the default for backward compat.
  authProvider  AuthProvider @default(LOCAL)
  // Provider-specific user id (Google's `sub` claim). Indexed for lookup
  // during OAuth login. Composite uniqueness with authProvider prevents
  // a Google `sub` and Apple `sub` from colliding when both are added.
  providerId    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Mood — current self-reported mood (token string, e.g. "calm", "anxious", "sad")
  mood          String?
  moodUpdatedAt DateTime?

  // Streaks — denormalized counters updated by ProgressService / DiarioService on activity
  currentStreakDays Int       @default(0)
  longestStreakDays Int       @default(0)
  streakLastDay     DateTime?

  // Soft delete with cooldown — finalized by background worker after 30 days
  deleteRequestedAt DateTime?

  // E2E crypto salt — base64url-encoded 16 random bytes, generated at register.
  // Used by the client to derive the master key with Argon2id (ADR 0007 §A).
  // The salt is NOT secret — leaking it doesn't help an attacker without the
  // password. Nullable for users registered before Sprint S6-crypto; new
  // registrations always populate it.
  cryptoSalt String?

  // Timestamp when the client confirmed it showed the BIP39 recovery seed
  // phrase modal (Sprint seed-and-password-rekey · ADR 0007 §G).
  // Null = modal pending. Once the client POSTs the acknowledgment we set
  // this and never bother the user again. The actual seed phrase is NOT
  // stored — it's the masterKey serialized and the server never sees it.
  cryptoSeedShownAt DateTime?

  stripeCustomerId String? @unique

  profile                 Profile?
  refreshTokens           RefreshToken[]
  progress                UserProgress[]
  subscription            Subscription?
  conversations           Conversation[]
  preferences             UserPreferences?
  readerPreferences       ReaderPreferences?
  notificationSettings    NotificationSettings?
  privacySettings         PrivacySettings?
  achievements            UserAchievement[]
  emailChangeRequests     EmailChangeRequest[]
  dataExportRequests      DataExportRequest[]
  authEvents              AuthEvent[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  onboardingState         OnboardingState?
  bookFavorites           BookFavorite[]
  bookBookmarks           BookBookmark[]
  bookReviews             BookReview[]
  dismissedPrompts        DismissedReflectionPrompt[]
  diaryEntries            DiaryEntry[]
  sharedDiaryEntries      SharedDiaryEntry[]
  billingUsageDays        BillingUsageDay[]
  voiceTranscriptions     VoiceTranscription[]
  ecoThreads              EcoThread[]
  highlights              Highlight[]
  annotations             Annotation[]
  readingSessions         ReadingSession[]
  weeklySummaries         WeeklySummary[]
  deviceTokens            DeviceToken[]
  liveActivityTokens      LiveActivityToken[]         @relation("UserLiveActivityTokens")
  therapistProfile        Therapist?                  @relation("UserAsTherapist")
  therapistFavorites      TherapistFavorite[]
  therapistReviews        TherapistReview[]
  therapySessions         TherapySession[]
  therapyPrescriptions    TherapyPrescription[]
  therapyNotifications    TherapyNotification[]
  crisisLogs              CrisisLog[]
  therapyTechnicalReports TherapyTechnicalReport[]
  authorBooks             AuthorBook[]                @relation("AuthorBookOwner")
  moodLogs                MoodLog[]

  // Sprint S43: last time we sent a re-engagement nudge (any channel). The
  // InactiveNudgeProcessor uses this to avoid spamming the same user
  // every night when they go quiet for a week.
  lastNudgedAt DateTime?

  @@unique([authProvider, providerId])
  @@index([email])
  @@index([providerId])
}

model Profile {
  id                String  @id @default(cuid())
  userId            String  @unique
  bio               String?
  country           String? // ISO 3166-1 alpha-2 (e.g. "EC", "MX")
  timezone          String? // IANA tz name (e.g. "America/Guayaquil")
  preferredLanguage String? // BCP 47 tag (e.g. "es", "en")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String    @id @default(cuid())
  // TODO senior: token stores SHA-256 hash — never the raw token
  token     String    @unique
  userId    String
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ─── Auth · password reset & email verification ──────────────────────────────
//
// Token storage strategy (mirrors AuthService.recordEvent's swallow-on-error
// pattern): we hash the one-time secret with SHA-256 before persistence. The
// raw token only exists in the email body. If the DB is compromised, an
// attacker still cannot reuse the tokens.
//
// `consumedAt` keeps the row after use for two reasons:
//   1. Audit — we can answer "did this user reset their password yesterday?"
//   2. Replay protection — a second call with the same token returns 410 Gone.
//
// Old rows (consumedAt + 30 days, or expiresAt + 7 days for unused tokens) can
// be GC'd by a future scheduled job. Not urgent.

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Onboarding · catalogs (seeded) ──────────────────────────────────────────
//
// Why tables and not TypeScript enums:
//  - OnboardingState references motivosIds + moodId. Tables give us referential
//    integrity (FK-able when we want to enforce) and i18n-friendly label storage.
//  - Editing the catalog = SQL UPDATE, no deploy needed.
//
// Seed populates a sensible default set. Updating in prod is a migration.

model OnboardingMotivo {
  id       String  @id // "ansiedad", "tristeza", "relaciones", ... — stable slug
  label    String
  icon     String // lucide-style token, e.g. "heart-pulse"
  order    Int     @default(0)
  isActive Boolean @default(true)

  @@index([isActive, order])
}

model OnboardingMood {
  id       String  @id // "calma", "foco", "energia", ...
  label    String
  swatch   String // hex color (e.g. "#A8C7E4") — drives the UI swatch
  order    Int     @default(0)
  isActive Boolean @default(true)

  @@index([isActive, order])
}

// ─── Onboarding · per-user state ─────────────────────────────────────────────
//
// 1:1 with User. Created lazily on first onboarding endpoint hit (intro / step1).
// Tracks WHAT the user picked during onboarding (audit + later analytics for
// Pulso). The user's long-term state (firstName, mood, voicePreference) lives
// in User / UserPreferences — onboarding writes there too, but THIS table is
// the historical record of the original picks.

model OnboardingState {
  id     String @id @default(cuid())
  userId String @unique

  // Step 1: chosen motivos. Stored as plain string[] for simplicity; the API
  // validates they exist in OnboardingMotivo at write time.
  motivosIds String[] @default([])

  // Step 2: initial mood pick. Distinct from User.mood (current mood, which
  // gets re-set every time the user changes it from Inicio).
  initialMoodId String?

  // Step 3: voice preference chosen at onboarding. Also written to
  // UserPreferences.voicePreference at the same time so the rest of the
  // app reads it from there. Stored here separately as immutable audit.
  initialVoicePreference String? // "marina" | "tomas" | "none"

  // Step 4: what we showed as the primary recommendation + what they picked.
  recommendedBookId String?
  chosenBookId      String?

  // Lifecycle
  startedAt             DateTime  @default(now())
  step1CompletedAt      DateTime?
  step2CompletedAt      DateTime?
  step3CompletedAt      DateTime?
  onboardingCompletedAt DateTime?
  onboardingSkippedAt   DateTime?

  // Tour (separate flow, optional, runs after onboarding completes)
  tourCompletedAt    DateTime?
  tourStepsCompleted Int       @default(0)

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Auth audit log ──────────────────────────────────────────────────────────
//
// Append-only log of every auth event (register, login, refresh, logout, plus
// failures). Captured synchronously in AuthService so the trail is guaranteed.
//
// Why we instrument now even without dashboards:
//   - Sprint S25 (Pulso · Funnel) materializes signup/login funnels from here.
//   - Security alerts (Sprint future): "N failed logins from same IP in 5min"
//     becomes a Redis aggregation over this stream.
//   - GDPR/data-export (Sprint S3 worker): user can download their auth history.
//
// userId is nullable because some events (LOGIN_FAIL on non-existent email)
// have no user to attach to. We still record the attempt with the supplied
// email so brute-force enumeration is detectable.

model AuthEvent {
  id        String   @id @default(cuid())
  // Free-form discriminator. Document the canonical set in apps/api/src/auth/auth-event.type.ts.
  // Examples: REGISTER · LOGIN_OK · LOGIN_FAIL · REFRESH · REFRESH_REUSED · LOGOUT
  type      String
  userId    String?
  email     String?
  ipAddress String?
  userAgent String?
  // Structured context (reason for failure, oauth provider, etc.). Always small.
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Per-user history (Pulso, data export)
  @@index([userId, createdAt(sort: Desc)])
  // Type filters (alerts: "all LOGIN_FAIL in last hour")
  @@index([type, createdAt(sort: Desc)])
  // IP-based abuse detection
  @@index([ipAddress, createdAt(sort: Desc)])
}

// ─── Book catalog (Sprint S5) ────────────────────────────────────────────────
//
// BookAuthor + BookCategory live as tables (not enums) because:
//   1. Editor de autor (B2B, Sprint S19) needs to write to BookAuthor at
//      runtime. An enum would require a migration on each new author.
//   2. Categorías are described as an open set in 03-biblioteca.md
//      ("ansiedad | vinculos | duelo | …"). Curated by content team.
//   3. Both can be ordered, translated, or marked inactive in the future
//      without schema churn.
//
// Book.cover is the design token (cool|warm|mixed). The real artwork URL
// lives in coverArtUrl. The front falls back to the gradient token when
// coverArtUrl is null — see 03-biblioteca.md §states.

model BookAuthor {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  // Professional title shown on book detail ("Dra. en Psicología Clínica")
  title         String?
  bio           String?
  avatarUrl     String?
  // Visible only when verified (banco de psicólogos colegiados). Detail UI
  // hides it when null.
  licenseNumber String?
  // Cover token used when avatar is missing.
  cover         String   @default("cool")
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  books Book[]
}

model BookCategory {
  id        String   @id @default(cuid())
  // Stable token for URLs/filters: "ansiedad", "vinculos", "duelo".
  slug      String   @unique
  label     String
  // Display order in filter sidebar.
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  books Book[]
}

model Book {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  // Shorter subtitle line shown next to title (optional).
  subtitle        String?
  // Short description on cards (1-2 sentences).
  description     String?
  // Long-form summary (markdown) for detail page.
  summary         String?
  // Design token (cool|warm|mixed). The frontend renders this as a gradient
  // when coverArtUrl is null. Stored as string for flexibility — we may add
  // new tokens without a migration.
  cover           String    @default("cool")
  // Legacy field — kept for backward compat with seeded data and the existing
  // ContentModule URL exposure. New artwork goes to coverArtUrl.
  coverUrl        String?
  coverArtUrl     String?
  // Total page count (nullable for audio-only or chapter-only books).
  pages           Int?
  // Sum of chapter durations. Denormalized for list/detail performance.
  // Recomputed on chapter create/delete via service.
  durationMinutes Int       @default(0)
  // Language tag (BCP 47): "es", "en". Defaults to Spanish for our market.
  language        String    @default("es")
  // TODO senior: totalChapters is a denormalized count — keep in sync on every Chapter create/delete
  totalChapters   Int       @default(0)
  isPublished     Boolean   @default(false)
  plan            Plan      @default(FREE)
  // Optional FK to author/category. Nullable so we can seed books before
  // wiring catalog (avoids chicken-and-egg in migration). Service requires it
  // on publish.
  authorId        String?
  categoryId      String?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  chapters  Chapter[]
  author    BookAuthor?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category  BookCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  favorites BookFavorite[]
  bookmarks BookBookmark[]
  reviews   BookReview[]

  @@index([authorId])
  @@index([categoryId])
  @@index([isPublished, publishedAt(sort: Desc)])
}

// User-scoped catalog state. Both are toggleable; both delete on user delete.
model BookFavorite {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
}

model BookBookmark {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
}

// One review per user per book. UI only allows submission when the user has
// completed the book (`UserProgress.completedAt != null` for every chapter).
// The service enforces this — no DB-level constraint.
model BookReview {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  rating    Int // 1..5, validated in DTO
  text      String // Markdown allowed; sanitized in UI
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId, createdAt(sort: Desc)])
  @@index([userId])
}

// Reflection prompts (Home dashboard). Curated by content team; rotated daily.
// `audience` is a coarse filter — "all" or a tier token. The service can also
// filter by mood/streak if needed in the future.
model ReflectionPrompt {
  id        String   @id @default(cuid())
  text      String
  audience  String   @default("all")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  dismissals DismissedReflectionPrompt[]

  @@index([isActive])
}

// Per-user dismissals (POST /reflection-prompts/:id/dismiss). The Home
// service excludes any prompt the user dismissed in the last 7 days.
model DismissedReflectionPrompt {
  id          String   @id @default(cuid())
  userId      String
  promptId    String
  dismissedAt DateTime @default(now())

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt ReflectionPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([userId, promptId])
  @@index([userId, dismissedAt(sort: Desc)])
}

model Chapter {
  id              String   @id @default(cuid())
  bookId          String
  order           Int
  title           String
  description     String?
  durationMinutes Int?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  book            Book             @relation(fields: [bookId], references: [id], onDelete: Cascade)
  audios          Audio[]
  exercises       Exercise[]
  progress        UserProgress[]
  blocks          ChapterBlock[]
  readingSessions ReadingSession[]

  @@unique([bookId, order])
  @@index([bookId])
}

model Audio {
  id              String   @id @default(cuid())
  chapterId       String
  title           String
  fileUrl         String
  durationSeconds Int
  transcription   String?
  createdAt       DateTime @default(now())

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
}

model Exercise {
  id        String       @id @default(cuid())
  chapterId String
  order     Int
  title     String
  type      ExerciseType
  content   Json
  createdAt DateTime     @default(now())

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  chapterId   String
  completedAt DateTime @default(now())
  score       Float?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
}

// ───────────────────────────────────────────────────────────────────────────
// Sprint S6 — LectorModule
//
// `ChapterBlock` rompe `Chapter` en bloques tipados. Inspirado en el modelo
// editorial tipo Notion del prototype `Lector RISE.html` (futuro) y los
// modos Libro/Guía del prototype `Lector.html`. Cada bloque vive en una
// `order` única dentro del capítulo y conoce su tipo, contenido y metadata
// opcional (e.g. exerciseId si KIND = EXERCISE, url si KIND = AUDIO/IMAGE).
//
// Por qué no `Chapter.body String` con markdown:
//   1. Highlights/annotations apuntan a bloques específicos — no rangos
//      en un string que cambia con cada edición editorial.
//   2. El "Modo Guía" sincroniza un transcript de audio con los bloques
//      del libro; necesita un anchor por bloque.
//   3. El editor de autor (Sprint S19) va a editar bloque por bloque,
//      no archivos markdown gigantes.
// ───────────────────────────────────────────────────────────────────────────

enum ChapterBlockKind {
  PARAGRAPH
  HEADING
  QUOTE
  EXERCISE
  AUDIO
  IMAGE
  PAUSE
}

model ChapterBlock {
  id        String           @id @default(cuid())
  chapterId String
  order     Int
  kind      ChapterBlockKind
  // Contenido del bloque. Para PARAGRAPH/HEADING/QUOTE es markdown plano.
  // Para EXERCISE/AUDIO/IMAGE el `meta` JSON contiene la referencia rica
  // y `content` puede traer un caption/título.
  content   String
  // Metadata estructurada según `kind` (exerciseId, audioUrl, imageUrl,
  // duration, caption, etc). Documentado en `apps/api/src/lector/README.md`.
  meta      Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  chapter     Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  highlights  Highlight[]
  annotations Annotation[]

  @@unique([chapterId, order])
  @@index([chapterId])
}

enum HighlightColor {
  YELLOW
  BLUE
  PINK
}

model Highlight {
  id          String         @id @default(cuid())
  userId      String
  blockId     String
  // Offsets dentro del `content` del bloque (UTF-16 code units, igual que
  // `Range.startOffset`/`endOffset` del DOM).
  startOffset Int
  endOffset   Int
  color       HighlightColor @default(YELLOW)
  // Nota opcional adjunta al subrayado. Si el user quiere sin nota → null.
  note        String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  block ChapterBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([userId, blockId])
  @@index([userId, createdAt(sort: Desc)])
}

model Annotation {
  id        String   @id @default(cuid())
  userId    String
  blockId   String
  // Texto plain — NO se cifra (no es parte del Diario E2E, ADR 0007 §G).
  // Diseño 05-lector.md trata las anotaciones como notas al libro, no
  // pensamiento personal sensible. Si en el futuro el producto pide
  // anotaciones cifradas, se introduce un campo separado.
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  block ChapterBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([userId, blockId])
  @@index([userId, createdAt(sort: Desc)])
}

// Sesión de lectura: una fila por (user, chapter). El heartbeat del cliente
// (PATCH /api/lector/session cada 5s) actualiza `lastBlockId`, `progressPct`
// y `timeSpentSec`. `completedAt` se setea cuando el user llega al último
// bloque (o presiona "Marcar como leído").
model ReadingSession {
  id           String    @id @default(cuid())
  userId       String
  chapterId    String
  lastBlockId  String?
  progressPct  Float     @default(0)
  timeSpentSec Int       @default(0)
  startedAt    DateTime  @default(now())
  lastSeenAt   DateTime  @updatedAt
  completedAt  DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId, lastSeenAt(sort: Desc)])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String             @unique
  stripePriceId        String
  stripeCustomerId     String
  status               SubscriptionStatus
  plan                 Plan
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
}

model StripeEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime
  createdAt     DateTime @default(now())

  @@index([stripeEventId])
}

// ─── Eco conversational AI (Sprint S10) ──────────────────────────────────────
//
// Hybrid encryption model for v1:
//   - User messages: client encrypts → server stores `textCiphertext + textNonce`.
//     Server also receives plaintext IN-FLIGHT to call the LLM and run crisis
//     detection, but NEVER persists it. The privacy spec enforces no logging.
//   - Assistant messages: LLM-generated, stored as plaintext in `assistantText`.
//     They're not the user's private input; encrypting them adds plumbing
//     without privacy upside for the v1 threat model.
//
// `EcoMessage.kind` lets the UI distinguish normal replies from crisis
// derivations and book/exercise suggestions:
//   - "user"        → user → eco
//   - "assistant"   → eco → user (regular reply)
//   - "crisis"      → eco → user (crisis derivation; no LLM call needed,
//                                  server-generated)
//   - "suggestion"  → eco → user (assistant suggesting a book/exercise;
//                                  carries an optional bookId/exerciseId)
//
// `EcoMessageReport` captures user-flagged bad answers for offline review.

enum EcoMessageKind {
  USER
  ASSISTANT
  CRISIS
  SUGGESTION
}

enum EcoMessageReportReason {
  HALLUCINATION
  OFF_TONE
  SENSITIVE_CONTENT
  CRISIS_MISHANDLED
  OTHER
}

model EcoThread {
  id              String   @id @default(cuid())
  userId          String
  // Generated client-side from the first user message, then encrypted with
  // the same ecoKey. Null until the first response is received. Used as a
  // "title" in the sidebar rail — client decrypts before render.
  titleCiphertext String?
  titleNonce      String?
  lastMessageAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages EcoMessage[]

  @@index([userId, lastMessageAt])
}

model EcoMessage {
  id              String         @id @default(cuid())
  threadId        String
  kind            EcoMessageKind
  // For USER messages: cipher payload encrypted client-side. NEVER null
  // for USER kind. Always null for non-USER kinds.
  textCiphertext  String?
  textNonce       String?
  // For ASSISTANT / CRISIS / SUGGESTION: LLM-generated plaintext.
  // Stored to make the thread re-readable without re-running inference.
  // Always null for USER kind.
  assistantText   String?
  // Suggestion metadata. Populated only when kind=SUGGESTION.
  suggestedBookId String?
  // Token accounting for billing/cost analysis. Zero for USER messages.
  inputTokens     Int            @default(0)
  outputTokens    Int            @default(0)
  createdAt       DateTime       @default(now())

  thread  EcoThread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  reports EcoMessageReport[]

  @@index([threadId, createdAt])
}

model EcoMessageReport {
  id        String                 @id @default(cuid())
  messageId String
  userId    String // denormalised so the report row is queryable without a join
  reason    EcoMessageReportReason
  comment   String?
  createdAt DateTime               @default(now())

  // Sprint S49 — resolution flow. NULL means "still open / awaiting review";
  // a non-null timestamp marks the row as triaged. `resolvedBy` is the ADMIN
  // userId that acted; `resolutionNote` is an optional short note explaining
  // what was done (e.g. "False positive — message was sensitive but on-tone").
  resolvedAt     DateTime?
  resolvedBy     String?
  resolutionNote String?

  message EcoMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([reason])
  // Sprint S49 — partial-ish index so `count(where: { resolvedAt: null })`
  // (the Pulso Overview backlog metric) doesn't degrade as the table grows.
  // Postgres supports proper partial indexes; the @@index here is a regular
  // composite that already narrows on the most-selective column.
  @@index([resolvedAt, createdAt])
}

// ─── Voice transcriptions (Sprint S8) ────────────────────────────────────────
//
// Audit row per transcription. Per ADR / docs/design/handoff/07-voz.md the
// audio is NEVER stored — only this metadata. Two uses:
//   1. Live quota counter — UsageService SUMs `durationSec` in the period.
//   2. BullMQ daily rollup — DailyUsageProcessor aggregates into
//      BillingUsageDay.voiceMinutes for Pulso admin.
//
// We intentionally store the provider (`whisper` | `deepgram`) so that
// future cost-attribution analytics can split per-vendor without us
// having to redo joins.
model VoiceTranscription {
  id          String   @id @default(cuid())
  userId      String
  durationSec Float
  language    String // "es" | "es-419" | "en" | ...
  provider    String // "whisper" | "deepgram" (also used to plan migration)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ─── Billing usage rollup (Sprint S7) ────────────────────────────────────────
//
// One row per user per UTC day. Populated by the BullMQ `daily-usage` job
// nightly at 02:00 UTC; not read by the live `/api/subscriptions/usage`
// endpoint (that one queries live tables with a 5-min Redis cache). This
// table exists for:
//   1. Pulso admin / cohort metrics — usage trends across the user base.
//   2. Quota auditing — "did this user actually exceed their limit on day X?"
//   3. Future churn analytics — usage decline as a leading indicator.
//
// The producer truncates `day` to UTC midnight. (userId, day) is unique so
// the rollup is idempotent: re-running for the same day re-computes the
// counters and overwrites the row.
model BillingUsageDay {
  id             String   @id @default(cuid())
  userId         String
  day            DateTime // UTC midnight of the day being rolled up
  booksCompleted Int      @default(0)
  ecoMessages    Int      @default(0)
  voiceMinutes   Float    @default(0)
  diaryEntries   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@index([day])
}

// ───────────────────────────────────────────────────────────────────────────
// Sprint S50 — Pulso v2 time series
//
// `PlatformMetricDaily` is a platform-wide daily snapshot that powers the
// sparklines + "vs last period" deltas in the admin Overview (S48). One row
// per UTC day, written by a nightly cron (`PlatformSnapshotProcessor` in
// `apps/api/src/jobs/processors/platform-snapshot.processor.ts`).
//
// Why a separate table instead of aggregating `BillingUsageDay` at query
// time:
//   - `BillingUsageDay` is per-user. Charting requires platform-wide totals,
//     and the count of active users (DAU) is its own metric, not a sum.
//   - The snapshot includes columns BillingUsageDay never tracked
//     (reportsOpened, reportsResolved, paidUsers, totalUsers).
//   - A pre-aggregated table is O(N days) to chart; aggregating on the fly
//     would scan millions of rows once the user base is non-trivial.
//
// Privacy contract:
//   - Every column is an integer count or a float (voiceMinutes). NO per-
//     user identifiers. Same invariant as `getOverview` (S48): rows are
//     safe to log + share inside the team.
// ───────────────────────────────────────────────────────────────────────────

// ───────────────────────────────────────────────────────────────────────────
// Sprint S51 — Cohort retention analysis
//
// `CohortRetentionWeek` materializes the classic SaaS retention triangle:
// one row per (signup-week, week-offset) describing how many users from
// the cohort who signed up that week were still active `weekOffset` weeks
// later. Rendered as a heatmap in /dashboard/admin/cohorts.
//
// Why a separate table instead of computing on the fly:
//   - The triangle has up to N_weeks × N_weeks cells (52 × 52 = 2704 at
//     1 year of history). Computing live would scan activity tables
//     repeatedly on every admin page view.
//   - Retention is a slow-changing metric — a Monday cron is fast enough.
//   - Materialising lets us track historical retention curves even if the
//     activity data is later pruned for cost reasons.
//
// Population strategy:
//   - `CohortRetentionProcessor` (Monday 03:00 UTC, after the daily
//     snapshot) recomputes the full triangle and upserts every cell.
//   - Idempotent on (cohortWeek, weekOffset) so retries are safe.
//
// Privacy invariant (same as PlatformMetricDaily):
//   - Every column is an integer count or timestamp. No per-user identifiers.
// ───────────────────────────────────────────────────────────────────────────

model CohortRetentionWeek {
  // Monday 00:00:00 UTC of the signup week. Combined with `weekOffset`
  // identifies a single cell of the retention triangle.
  cohortWeek DateTime

  // 0 = signup week, 1 = +1 week, etc. The processor caps weekOffset to
  // 52 (1 year) — older offsets would mostly be empty and the heatmap
  // would be unreadable.
  weekOffset Int

  // Total users whose `createdAt` fell within `cohortWeek..+7d` UTC.
  // Same value across all rows of a given cohortWeek; denormalised so
  // a single SELECT can render the heatmap without a self-join.
  cohortSize Int @default(0)

  // Distinct users from this cohort with ANY activity (diary, eco USER,
  // voice, reader) inside `[cohortWeek + weekOffset*7d, +1 week]`.
  activeUsers Int @default(0)

  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@id([cohortWeek, weekOffset])
  @@index([cohortWeek(sort: Desc)])
}

model PlatformMetricDaily {
  // UTC midnight of the day being snapshotted. We use the date as the PK
  // so the upsert in the cron is naturally idempotent — re-running today's
  // snapshot just overwrites the row.
  day DateTime @id

  // Users block
  totalUsers Int @default(0) // cumulative count at snapshot time
  newUsers   Int @default(0) // signups within the day
  paidUsers  Int @default(0) // cumulative PRO/ANNUAL/B2B at snapshot time
  dau        Int @default(0) // distinct active users in the day

  // Content block — created within the day
  diaryEntries    Int   @default(0)
  ecoMessages     Int   @default(0) // USER kind only
  ecoCrisis       Int   @default(0)
  voiceMinutes    Float @default(0) // sum of durationSec / 60
  readingSessions Int   @default(0) // ReadingSession.lastSeenAt within day

  // Pulso operations block — events on EcoMessageReport within the day
  reportsOpened   Int @default(0) // rows created in the day
  reportsResolved Int @default(0) // rows whose resolvedAt fell in the day

  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([day(sort: Desc)])
}

// ───────────────────────────────────────────────────────────────────────────
// Sprint S10 — PatronesModule (Pro feature)
//
// `WeeklySummary` is a per-week LLM-generated reflection card. The server
// composes a prompt from the user's mood pattern + entry count of the last
// 7 days (NOT the entry content — that's still E2E-encrypted), asks
// Anthropic for a short editorial paragraph, and persists it.
//
// Privacy note:
//   - `narrative` is plain text. The aggregate inputs (mood + count) are
//     non-sensitive metadata already visible to the server. The output is
//     a paraphrase of those aggregates, not of any cifrado entry body.
//   - Users who opt-OUT of Eco/insights (UserPrivacySettings) skip this
//     entirely; their `weekly-summary` job is a no-op.
//   - When TerapiaModule (S13) lands, sharing this snapshot with a
//     therapist re-encrypts it with the therapist's ephemeral key — same
//     pattern as SharedDiaryEntry.
// ───────────────────────────────────────────────────────────────────────────

model WeeklySummary {
  id          String   @id @default(cuid())
  userId      String
  // UTC midnight of the Monday that opens the summary week. Combined with
  // userId as a unique key so the regenerate endpoint is idempotent.
  weekStart   DateTime
  // Headline rendered as the card title. Server-trimmed at 80 chars to
  // avoid LLM-generated runaway lengths.
  headline    String
  // Editorial paragraph rendered as the card body. Stored plain (see
  // §Privacy note above).
  narrative   String
  // How many DiaryEntry rows landed in the week. Recorded so the UI can
  // show "5 entradas esta semana" without re-querying.
  entriesUsed Int      @default(0)
  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
}

// ─── AI / RAG models ──────────────────────────────────────────────────────────

model ContentChunk {
  id        String                       @id @default(cuid())
  bookId    String
  chapterId String?
  content   String
  // SHA-256 of content — used for idempotent upsert during ingest
  chunkHash String                       @unique
  metadata  Json
  // voyage-3 produces 1024-dimensional embeddings
  embedding Unsupported("vector(1024)")?
  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt

  @@index([bookId])
  @@index([chapterId])
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([userId])
}

enum MessageRole {
  USER
  ASSISTANT
}

model ConversationMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  inputTokens    Int         @default(0)
  outputTokens   Int         @default(0)
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ─── User · preferences, notifications, privacy ───────────────────────────────

model UserPreferences {
  id                String   @id @default(cuid())
  userId            String   @unique
  // "marina" | "tomas" | "none"
  voicePreference   String   @default("none")
  moodPrompts       Boolean  @default(true)
  // "morning" | "noon" | "evening" | "any"
  bestTime          String   @default("any")
  weeklyGoalMinutes Int      @default(60)
  // "system" | "light" | "dark"
  theme             String   @default("system")
  // BCP 47: "es-419" | "es-ES"
  language          String   @default("es-419")
  // Sprint B1 — ambient theme picker. One of "calma" | "enfoque" | "energia" | "noche".
  // Defaults to "calma" (the base palette). Free for all plans (decisión B1).
  ambient           String   @default("calma")
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Sprint B1 — mood time series. One row per mood check-in from the Topbar
// MoodChip or the Diario composer. Source-of-truth for Patrones, Insight del
// día, and weekly digests. User.mood + User.moodUpdatedAt stay as denormalized
// "current mood" cache so the existing /api/home payload doesn't need to JOIN
// MoodLog on every request.
model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  // Token validated against DIARY_MOODS catalog at the DTO layer.
  mood      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model ReaderPreferences {
  id         String   @id @default(cuid())
  userId     String   @unique
  // "serif" | "sans"
  font       String   @default("serif")
  fontSize   Int      @default(18)
  // "system" | "light" | "sepia" | "dark"
  theme      String   @default("system")
  lineHeight Float    @default(1.6)
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  dailyReminder    Boolean  @default(true)
  // HH:MM (local user time, interpreted with Profile.timezone)
  reminderTime     String   @default("20:00")
  streakReminders  Boolean  @default(true)
  ecoReplies       Boolean  @default(true)
  terapiaReminders Boolean  @default(true)
  weeklyReport     Boolean  @default(true)
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrivacySettings {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  shareDiaryWithTherapist  Boolean   @default(false)
  anonymizedAnalytics      Boolean   @default(true)
  marketingEmail           Boolean   @default(false)
  // Mirrors of DataExportRequest / User.deleteRequestedAt so the FE has them in one read
  dataExportRequestedAt    DateTime?
  accountDeleteRequestedAt DateTime?
  updatedAt                DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Achievements ─────────────────────────────────────────────────────────────

model Achievement {
  // Stable string id (e.g. "first-chapter", "7-day-streak") — seeded
  id             String   @id
  label          String
  description    String
  // Lucide-style token (e.g. "book-open", "flame")
  icon           String
  progressTarget Int
  category       String?
  createdAt      DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id              String    @id @default(cuid())
  userId          String
  achievementId   String
  progressCurrent Int       @default(0)
  unlockedAt      DateTime?
  updatedAt       DateTime  @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

// ─── Account lifecycle requests ───────────────────────────────────────────────

model EmailChangeRequest {
  id         String    @id @default(cuid())
  userId     String
  newEmail   String
  // SHA-256 hash of the one-time verification token — never store the raw token
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DataExportRequest {
  id          String    @id @default(cuid())
  userId      String
  // "PENDING" | "PROCESSING" | "READY" | "FAILED"
  status      String    @default("PENDING")
  fileUrl     String?
  expectedAt  DateTime
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Diary · E2E-encrypted journal entries (Sprint S6 · ADR 0007) ────────────
//
// PRIVACY-CRITICAL — read this comment before touching any field below.
//
// The user encrypts the entry body on-device with their per-user diaryKey
// derived from password via Argon2id. The server stores `textCiphertext` and
// `textNonce` opaque; the server NEVER:
//   - receives, derives, or holds the diaryKey
//   - logs textCiphertext / textNonce (CI grep enforces this; ADR 0007 §F)
//   - exposes any endpoint that returns plaintext
//
// Plaintext metadata (mood, promptId, tags, audioUrl) is intentionally kept
// outside the cipher so the catalog UI can filter and the home stats can
// count without round-tripping the cipher. These fields MUST NOT contain
// sensitive content — the design (06-diario.md) commits to that.

model DiaryEntry {
  id     String @id @default(cuid())
  userId String

  // base64url ciphertext of XChaCha20-Poly1305(plaintext, diaryKey, nonce, AAD).
  // Capped at ~1 MB at the DTO layer (`@Length`). PostgreSQL TEXT, no
  // compression at the row level — the cipher is already incompressible.
  textCiphertext String

  // base64url 24-byte random nonce. Generated client-side per write. Stored
  // separately from the cipher so a future nonce-handling change does not
  // require a payload migration.
  textNonce String

  // Excerpt cipher (first ~80 chars of plaintext, encrypted with the same
  // diaryKey + a different nonce). Sent in list responses so the user gets a
  // preview without downloading every full body. Optional: client may write
  // null if the entry is too short.
  excerptCiphertext String?
  excerptNonce      String?

  // Plaintext metadata — explicitly non-sensitive per the design contract.
  mood     String // token: "calma" | "foco" | "energia" | … (validated against OnboardingMood)
  // "free" | "prompted" | "voz" — denormalized for filtering/analytics.
  kind     String   @default("free")
  promptId String? // FK is intentionally a soft pointer to DiaryPrompt
  tags     String[]

  // Voice entry attachments. Audio is NOT encrypted at rest — design 07-voz.md
  // says transcription is destroyed after extraction so no plaintext lives on
  // disk anyway. Only the URL + duration travel here.
  audioUrl         String?
  audioDurationSec Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt       DiaryPrompt?       @relation(fields: [promptId], references: [id], onDelete: SetNull)
  sharedCopies SharedDiaryEntry[]
  // The promptId path is rare; soft FK does not need an index of its own.

  // Range scans for the list view (last N entries, optionally filtered by mood).
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, mood])
}

// Re-encrypted copy of a diary entry shared with a therapist for a bounded
// window. The server is a blind mailbox: it stores `ciphertextForTherapist`
// + `wrappedKey` + the user's one-shot pubkey, all base64url, and NEVER
// touches them. Therapist reads via /api/terapia/shared-entries/:id (v2).
//
// Expiry is honored by a scheduled job (S3 jobs pipeline) — when v2
// TherapyModule lands the worker will delete rows where `expiresAt < now()`.
model SharedDiaryEntry {
  id          String  @id @default(cuid())
  // Nullable so the relation can be SetNull on entry delete — that lets us
  // keep the audit trail "user U shared an entry with therapist T at time X"
  // even after U deletes the original entry.
  entryId     String?
  // therapistId is a soft pointer — TherapyModule is v2 and may live in a
  // separate service. We store the string and validate at use-time.
  therapistId String
  userId      String

  ciphertextForTherapist String // base64url AEAD(plaintext, ephemeralKey)
  wrappedKey             String // base64url AEAD(ephemeralKey, ECDH(userPriv, therapistPub))
  userOneShotPubKey      String // base64url X25519 pubkey used in the ECDH

  // Server-enforced TTL. Default 7 days per ADR 0007 §E. The user can shorten
  // at share-time (DTO), but cannot extend beyond 30 days.
  expiresAt DateTime
  createdAt DateTime @default(now())

  // SetNull on entry delete so the audit trail (who shared what with whom)
  // survives even when the source entry is gone.
  entry DiaryEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([therapistId, expiresAt])
}

// Curated daily prompts surfaced by GET /api/diario/prompt-of-the-day.
// Rotation is deterministic by day-of-year hash so the user sees the same
// prompt all day (cached client-side) without a server-side schedule.
model DiaryPrompt {
  id        String   @id @default(cuid())
  text      String
  // Coarse audience filter. v1 only uses "all"; future tier-aware prompts
  // will reuse the same column.
  audience  String   @default("all")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  entries DiaryEntry[]

  @@index([isActive])
}

// ─── Notifications (Sprint S43) ───────────────────────────────────────────
//
// Push tokens registered by the mobile app via expo-notifications. One row
// per (user, device) pair. We keep `lastSeenAt` so InactiveNudgeProcessor
// can prune stale tokens after ~90 days (Expo tokens rotate).

enum DevicePlatform {
  EXPO
  WEB
}

model DeviceToken {
  id          String         @id @default(cuid())
  userId      String
  platform    DevicePlatform
  // Expo push token format: "ExponentPushToken[xxx]" or "ExpoPushToken[xxx]".
  token       String         @unique
  deviceLabel String?
  createdAt   DateTime       @default(now())
  lastSeenAt  DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Live Activities (Sprint E.5) ──────────────────────────────────────────
//
// iOS 16.1+ Live Activities (Dynamic Island) require a per-activity APNs
// push token DISTINCT from the regular device token. The mobile app calls
// `Activity.start()`, gets a token, and registers it here. The backend then
// pushes contentState updates via APNs HTTP/2 with the `liveactivity` topic
// suffix (`{bundleId}.push-type.liveactivity`).
//
// `activityId` is the mobile-side correlation ID (matches `EcoThread.id`,
// `BookChapter.id`, or `TherapySession.id` depending on `kind`).
//
// `kind` tells the worker which contentState schema to send. Three kinds
// in v1: TERAPIA_SESSION, LECTOR_ACTIVE, ECO_ACTIVE.
//
// `dismissedAt` is set when the mobile app or the server explicitly ends
// the activity. Stale rows are pruned weekly (future sprint).
//
// Privacy: contentState NEVER includes Diario ciphertext, Eco message text,
// or any seed-phrase-derived material — only opaque IDs + counters that the
// mobile widget renders locally.

enum LiveActivityKind {
  TERAPIA_SESSION
  LECTOR_ACTIVE
  ECO_ACTIVE
}

model LiveActivityToken {
  id          String           @id @default(cuid())
  userId      String
  activityId  String
  kind        LiveActivityKind
  // APNs push token specific to this activity instance (NOT the device's
  // regular push token). 32–64 hex chars. Distinct from `DeviceToken.token`.
  pushToken   String           @unique
  // Bundle ID of the app that started the activity. Used to construct the
  // APNs topic: `{bundleId}.push-type.liveactivity`.
  bundleId    String
  createdAt   DateTime         @default(now())
  dismissedAt DateTime?

  user User @relation("UserLiveActivityTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@index([userId])
  @@index([dismissedAt])
}

// ─── Terapia (Sprint S62) ──────────────────────────────────────────────────
//
// Therapist directory + booking + session lifecycle for the Terapia vertical.
// Design: docs/design/handoff/11-terapia.md (Pantallas 1–7 boundary v1).
// Video provider: Daily.co (ADR 0014). Crisis endpoint is public (no auth).
//
// Privacy:
//  - Pre-session intention is E2E encrypted (intentionCiphertext + nonce)
//    following the same pattern as Diario (ADR 0007). Server never sees
//    plaintext.
//  - Post-session note from the user is also E2E encrypted.
//  - Therapist notes (visible only to therapist) come later in B2B (S19+) —
//    NOT in this sprint.
//  - Crisis log is metadata-only (trigger + contactedLineId), no content.

enum TherapyModality {
  INDIVIDUAL
  COUPLE
  FAMILY
}

enum TherapySessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  MISSED
}

enum TherapyPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum TherapyPrescriptionKind {
  BOOK
  AUDIO
  EXERCISE
  CARTA
}

enum TherapyNotificationKind {
  SESSION_REMINDER_24H
  SESSION_REMINDER_1H
  SESSION_STARTED
  SESSION_RESCHEDULED
  SESSION_CANCELLED
  PRESCRIPTION_NEW
  PRESCRIPTION_DUE_SOON
  CRISIS_FOLLOWUP
}

model Therapist {
  id                   String            @id @default(cuid())
  // Optional FK to a User row when the therapist also has a USER login. Most
  // therapists in v1 don't have an app account — they're catalog rows curated
  // by ops. Author dashboard (B2B v2) will make this FK required.
  userId               String?           @unique
  name                 String
  initials             String
  title                String
  // Credential
  licenseNumber        String            @unique
  licenseVerified      Boolean           @default(false)
  // Card data
  avatarUrl            String?
  coverToken           String            @default("warm")
  bioShort             String
  bioLong              String?
  approach             String? // enfoque terapéutico (markdown short)
  specialties          String[] // ["ansiedad", "duelo", "pareja"]
  modalities           TherapyModality[]
  languages            String[] // ["es-EC", "en"]
  genderId             String? // self-declared ("femenino", "masculino", "no-binario", null)
  // Pricing
  priceUsd             Float
  currency             String            @default("USD")
  acceptsInsurance     Boolean           @default(false)
  // Ratings (denormalized from TherapistReview)
  avgRating            Float             @default(0)
  reviewsCount         Int               @default(0)
  // Discoverability
  isActive             Boolean           @default(true)
  popularity           Int               @default(0)
  // Policies (short markdown)
  firstSessionPolicy   String?
  cancellationPolicy   String?
  videoPresentationUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User?                   @relation("UserAsTherapist", fields: [userId], references: [id], onDelete: SetNull)
  availability TherapistAvailability[]
  sessions     TherapySession[]
  favorites    TherapistFavorite[]
  reviews      TherapistReview[]

  @@index([isActive])
  @@index([popularity])
}

// Recurring weekly availability slots. Bookings consume these via the
// availability endpoint which projects them onto the next 14 days.
model TherapistAvailability {
  id          String @id @default(cuid())
  therapistId String
  // 0 = Sunday, 6 = Saturday (Postgres EXTRACT(DOW)).
  dayOfWeek   Int
  // Minutes since midnight in the therapist's local TZ.
  startMin    Int
  endMin      Int
  // IANA TZ — independent of the user's. Crossfade in projection.
  timezone    String

  therapist Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId, dayOfWeek])
}

model TherapistFavorite {
  id          String   @id @default(cuid())
  userId      String
  therapistId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  therapist Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([userId, therapistId])
  @@index([userId])
}

model TherapistReview {
  id          String   @id @default(cuid())
  therapistId String
  userId      String
  rating      Int // 1-5
  // Public review text (NOT E2E encrypted; this is what other users see).
  text        String?
  // Tags from a curated list ("escucha activa", "puntual", ...). Filterable.
  tags        String[] @default([])
  createdAt   DateTime @default(now())

  therapist Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([therapistId, userId])
  @@index([therapistId])
}

model TherapySession {
  id          String               @id @default(cuid())
  userId      String
  therapistId String
  scheduledAt DateTime
  durationMin Int                  @default(50)
  modality    TherapyModality
  status      TherapySessionStatus @default(SCHEDULED)
  priceUsd    Float
  currency    String               @default("USD")

  // Initial reason picked at booking (curated catalog id, no free text here)
  firstReasonId String?

  // Daily.co room (created lazily ~5 min before scheduledAt)
  roomUrl       String?
  roomCreatedAt DateTime?

  // Payment (Sprint S64). Drives lifecycle:
  // PENDING → just created, Stripe Checkout still open.
  // PAID    → Stripe webhook confirmed. Therapist can rely on this.
  // FAILED  → Stripe declined; sweeper auto-cancels.
  // REFUNDED→ user cancelled within policy.
  // stripeCheckoutSessionId correlates webhook events.
  paymentStatus           TherapyPaymentStatus @default(PENDING)
  stripeCheckoutSessionId String?

  // E2E encrypted pre-session intention (ADR 0007)
  intentionCiphertext String?
  intentionNonce      String?
  // Mood at check-in (token, plaintext metadata)
  checkInMood         String?
  // Diary entries the user chose to share (re-encrypted ephemeral, stored
  // as their IDs — the actual re-encrypt blob lives in SharedDiaryEntry).
  sharedEntryIds      String[] @default([])

  // Post-session feedback from the user
  feedbackRating         Int? // 1-5
  feedbackTags           String[] @default([])
  feedbackNoteCiphertext String?
  feedbackNoteNonce      String?

  // Lifecycle audit
  startedAt         DateTime?
  endedAt           DateTime?
  // Sprint S70: real session length captured from Daily.co webhook
  // (meeting.ended event). Distinct from `durationMin` (planned duration).
  actualDurationSec Int?
  cancelledAt       DateTime?
  cancelReason      String?
  rescheduledFromId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  therapist Therapist @relation(fields: [therapistId], references: [id])

  prescriptions    TherapyPrescription[]
  notifications    TherapyNotification[]
  technicalReports TherapyTechnicalReport[]

  @@index([userId, scheduledAt])
  @@index([therapistId, scheduledAt])
  @@index([status, scheduledAt])
  @@index([paymentStatus])
}

model TherapyPrescription {
  id          String                  @id @default(cuid())
  sessionId   String? // optional: standalone prescriptions allowed
  userId      String
  therapistId String
  kind        TherapyPrescriptionKind
  // For BOOK: bookId. For AUDIO: contentId. For EXERCISE: exerciseId.
  // For CARTA: free-form Cloudflare R2 URL (PDF or text snapshot).
  targetId    String
  dosage      String? // "1 capítulo / día"
  note        String? // therapist's note to the user (plaintext, opt-in by terapeuta)
  dueBy       DateTime?
  completedAt DateTime?
  createdAt   DateTime                @default(now())

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  session TherapySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, completedAt])
}

model TherapyNotification {
  id        String                  @id @default(cuid())
  userId    String
  sessionId String?
  kind      TherapyNotificationKind
  title     String
  body      String
  actionUrl String?
  createdAt DateTime                @default(now())
  readAt    DateTime?

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  session TherapySession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// Crisis log — auditoría sin contenido sensible. POST is opt-in for the
// user; the public GET endpoint never requires the log.
enum CrisisTrigger {
  ECO_SAFETY_LAYER
  HOME_BUTTON
  PROFILE_LINK
  THERAPIST_SUGGESTION
}

model CrisisLog {
  id              String        @id @default(cuid())
  userId          String?
  trigger         CrisisTrigger
  contactedLineId String?
  country         String? // ISO 3166-1 alpha-2
  createdAt       DateTime      @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

// ─── Terapia · Technical reports (Sprint S65) ──────────────────────────────
//
// User-side technical issues during a video session. Lets ops/QA see
// patterns (audio fails on Android, etc) and gives the user a clear
// channel to flag problems instead of just leaving the session.
//
// Privacy: description is plaintext but capped at 500 chars. No screenshots,
// no logs. Ops curates a follow-up via email if needed (out of band).

enum TherapyTechnicalIssue {
  AUDIO_FAILED
  VIDEO_FAILED
  CONNECTION_DROPPED
  THERAPIST_NO_SHOW
  OTHER
}

model TherapyTechnicalReport {
  id          String                @id @default(cuid())
  sessionId   String
  userId      String
  issue       TherapyTechnicalIssue
  description String                @db.VarChar(500)
  createdAt   DateTime              @default(now())

  session TherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([issue, createdAt])
}

// ─── Author module (Sprint S71 — B2B Editor de autor) ────────────────────────

enum AuthorBookStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

// AuthorBook — the *authored* book (Author's workspace).
// Distinct from `Book` (the catalog row consumed by readers). When status
// transitions to PUBLISHED, the AuthorBook is copy-on-publish to Book +
// ChapterBlock so the lector reads from the same models as the public catalog.
// `publishedBookId` keeps the link for republish / unpublish flows.
model AuthorBook {
  id            String           @id @default(cuid())
  authorUserId  String
  title         String
  subtitle      String?
  summary       String?
  status        AuthorBookStatus @default(DRAFT)
  // Cover: same shape as Book.cover (warm/cool/mixed/custom).
  cover         String           @default("warm")
  coverArtUrl   String?
  // Optional category/language target — set at publication.
  categoryId    String?
  language      String           @default("es")
  // Link to public Book when published (null when DRAFT/IN_REVIEW/ARCHIVED).
  publishedBookId String?        @unique
  publishedAt   DateTime?
  archivedAt    DateTime?
  // Last submission to review (set at publish-request). Used by Pulso to
  // count pending reviews and by the publication checklist UI.
  submittedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  author          User                       @relation("AuthorBookOwner", fields: [authorUserId], references: [id], onDelete: Cascade)
  chapters        AuthorBookChapter[]
  publicationLogs AuthorPublicationRequest[]

  @@index([authorUserId, status])
  @@index([status, submittedAt])
}

// AuthorBookChapter — chapter in editing. blocks: Json mirrors the
// ChapterBlock[] shape used by the lector but pre-publication.
// `version` increments each save so the editor can show concurrent-edit
// conflict warnings (compare-and-swap).
model AuthorBookChapter {
  id        String   @id @default(cuid())
  bookId    String
  n         Int // 1-based ordering
  title     String   @default("")
  subtitle  String?
  // Blocks: array of { kind, content, meta? } — same shape as ChapterBlock.
  blocks    Json     @default("[]")
  // Editor lifecycle. Authors can toggle a chapter's visibility per release.
  isLocked  Boolean  @default(false) // visible to Pro only when locked
  isHidden  Boolean  @default(false) // hide from readers entirely
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book AuthorBook @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, n])
  @@index([bookId])
}

// Audit trail of submissions to review. One row per submit; `reviewState`
// tracks the current verdict.
model AuthorPublicationRequest {
  id          String   @id @default(cuid())
  bookId      String
  submittedAt DateTime @default(now())
  // PENDING, APPROVED, REJECTED — string instead of enum for cheap evolution.
  reviewState String   @default("PENDING")
  // Admin's editorial feedback (Markdown short). Surfaces in the publication
  // checklist on the editor side.
  feedback    String?
  reviewedAt  DateTime?
  reviewedBy  String?

  book AuthorBook @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, submittedAt])
  @@index([reviewState, submittedAt])
}

// Sprint S72 — Audit del cambio de rol de un usuario realizado por un admin
// desde Pulso. Trail mínimo para responder "quién promovió a quién y cuándo".
model RoleChangeLog {
  id           String   @id @default(cuid())
  targetUserId String
  oldRole      Role
  newRole      Role
  changedBy    String // admin user id
  reason       String?
  changedAt    DateTime @default(now())

  @@index([targetUserId, changedAt])
  @@index([changedBy, changedAt])
}

// Sprint S71.C-revenue — earnings + payout settings para autores B2B.
// Una fila por (autor, libro?, mes). bookId es opcional para earnings
// agregadas (todos los libros del autor en ese mes). El servicio del
// autor solo lee; el seed/inserción real viene de Pulso v2 o un job
// futuro de agregación (deuda S71.D).

enum EarningStatus {
  PENDING
  PAID
}

model AuthorEarning {
  id               String        @id @default(cuid())
  authorUserId     String
  bookId           String?
  // Mes representado como el día 1 a 00:00 UTC. Facilita queries por
  // rango y aggregations YTD / lastMonth.
  month            DateTime
  // Todos los amounts en cents (USD por v1) para evitar float drift.
  grossCents       Int
  platformFeeCents Int
  netCents         Int
  status           EarningStatus @default(PENDING)
  paidAt           DateTime?
  paymentMethod    String?
  paymentReference String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([authorUserId, month])
  @@index([status, month])
}

// Settings de cobro del autor. Method es free-form porque varía mucho
// por país (transferencia EC, PayPal, Payphone, manual). Los detalles
// específicos van en `details` JSON.
model AuthorPayoutSetting {
  id           String   @id @default(cuid())
  authorUserId String   @unique
  // Una de: bank_ec | paypal | payphone | manual
  method       String   @default("manual")
  // JSON específico al método: { iban, accountHolder, bankName, ... }
  details      Json     @default("{}")
  taxId        String?
  legalName    String?
  legalAddress String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
