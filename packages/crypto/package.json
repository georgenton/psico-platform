{
  "name": "@psico/crypto",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/ciphers": "^1.2.1",
    "@noble/hashes": "^1.7.1",
    "@scure/bip39": "^1.5.0"
  },
  "devDependencies": {
    "@psico/eslint-config": "workspace:*",
    "@psico/typescript-config": "workspace:*",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^2.0.0"
  }
}
