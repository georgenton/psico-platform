# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5433/psico_dev?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# App
PORT=3001
ALLOWED_ORIGINS="http://localhost:3000"

# Node
NODE_ENV="development"

# Cloudflare R2 (S3-compatible object storage)
# Account ID: found in Cloudflare dashboard → R2 → Account ID (top right)
R2_ACCOUNT_ID="your-cloudflare-account-id"
# R2 API tokens: Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
# Bucket name created in R2 dashboard
R2_BUCKET_NAME="psico-media"
# Public URL: enable "Public access" on the bucket or use a custom domain
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"
